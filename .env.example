# =============================================================================
# .env.example — CRM Customer Intelligence Module
# Copy to .env and fill in your values. Never commit .env.
# =============================================================================

# SQL Server connection
# For Windows Authentication (most common for local SQL Server):
DB_SERVER=localhost
DB_NAME=CRM_Analytics
DB_TRUSTED_CONNECTION=yes

# For SQL Server Authentication (uncomment and fill):
# DB_SERVER=your_server_name_or_ip
# DB_NAME=CRM_Analytics
# DB_TRUSTED_CONNECTION=no
# DB_USERNAME=your_sql_login
# DB_PASSWORD=your_password

# ODBC driver — must match what's installed on your machine.
# Check installed drivers: odbcinst -q -d  (Linux/macOS)
#                          Get-OdbcDriver -Platform '64-bit'  (PowerShell)
# DB_DRIVER=ODBC Driver 17 for SQL Server

# Optional: path override for raw data CSVs
# Defaults to data/raw/Brazilian E-Commerce Public Dataset by Olist/
# DATA_DIR=C:\path\to\your\data\folder
