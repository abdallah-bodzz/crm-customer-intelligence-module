{
  "name": "Warm Clay",

  "dataColors": [
    "#B45F3A",
    "#5FA968",
    "#A85070",
    "#3E7E9E",
    "#C68A3A",
    "#7A5F9E",
    "#8F6F5A",
    "#6B8B5A",
    "#2E6B85",
    "#9A7A3D"
  ],

  "bad":     "#B45F3A",
  "neutral": "#A67B5B",
  "good":    "#5FA968",

  "minimum": "#B45F3A",
  "center":  "#D4936A",
  "maximum": "#5FA968",

  "background": "#F5F0EA",
  "foreground":  "#3D3630",
  "tableAccent": "#B45F3A",

  "textClasses": {
    "callout": {
      "fontFace": "'Inter Light', 'Segoe UI Light', wf_segoe-ui_light, helvetica, arial, sans-serif",
      "fontSize": 30,
      "color": "#3D3630"
    },
    "title": {
      "fontFace": "'Inter SemiBold', 'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif",
      "fontSize": 13,
      "color": "#3D3630"
    },
    "header": {
      "fontFace": "'Inter', 'Segoe UI', wf_segoe-ui_normal, helvetica, arial, sans-serif",
      "fontSize": 11,
      "color": "#7A7068"
    },
    "label": {
      "fontFace": "'Inter', 'Segoe UI', wf_segoe-ui_normal, helvetica, arial, sans-serif",
      "fontSize": 11,
      "color": "#5A524A"
    }
  },

  "visualStyles": {

    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FCF9F6" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#857565" } },
            "radius": 30
          }
        ],
        "visualCorners": [
          { "radius": 30 }
        ],
        "title": [
          {
            "show": true,
            "fontFamily": "Inter SemiBold",
            "fontSize": 13,
            "color": { "solid": { "color": "#3D3630" } },
            "alignment": "Left",
            "background": { "solid": { "color": "#FCF9F6" } }
          }
        ],
        "labels": [
          {
            "show": true,
            "color": { "solid": { "color": "#5A524A" } },
            "fontSize": 11,
            "fontFamily": "Inter"
          }
        ],
        "legend": [
          {
            "show": true,
            "position": "TopRight",
            "fontFamily": "Inter",
            "fontSize": 11,
            "color": { "solid": { "color": "#7A7068" } }
          }
        ],
        "tooltips": [
          {
            "fontFamily": "Inter",
            "fontSize": 11,
            "color": { "solid": { "color": "#3D3630" } },
            "background": { "solid": { "color": "#FCF9F6" } }
          }
        ]
      }
    },

    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F5F0EA" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#EDE5DC" } }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": { "solid": { "color": "#F5F0EA" } },
            "foregroundColor": { "solid": { "color": "#3D3630" } },
            "border": true,
            "borderColor": { "solid": { "color": "#E8DDD2" } },
            "headerSize": 13,
            "fontFamily": "Inter SemiBold"
          }
        ],
        "filterCard": [
          {
            "$id": "Available",
            "backgroundColor": { "solid": { "color": "#FCF9F6" } },
            "foregroundColor": { "solid": { "color": "#3D3630" } },
            "border": true,
            "borderColor": { "solid": { "color": "#E8DDD2" } },
            "inputBoxColor": { "solid": { "color": "#F5F0EA" } },
            "textSize": 11,
            "fontFamily": "Inter"
          },
          {
            "$id": "Applied",
            "backgroundColor": { "solid": { "color": "#F2E9DD" } },
            "foregroundColor": { "solid": { "color": "#3D3630" } },
            "border": true,
            "borderColor": { "solid": { "color": "#B45F3A" } },
            "inputBoxColor": { "solid": { "color": "#F5F0EA" } },
            "checkboxAndApplyColor": { "solid": { "color": "#B45F3A" } },
            "textSize": 11,
            "fontFamily": "Inter"
          }
        ]
      }
