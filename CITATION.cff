references:
  - type: dataset
    title: "Brazilian E-Commerce Public Dataset by Olist"
    authors:
      - name: "Olist"
    url: "https://www.kaggle.com/datasets/olistbr/brazilian-ecommerce"
    license: "CC-BY-NC-SA-4.0"
    notes: >
      Raw CSV files are not redistributed in this repository. Download
      directly from Kaggle and place under
      data/raw/Brazilian E-Commerce Public Dataset by Olist/

  - type: software
    title: "LeIA — Léxico para Inferência Adaptada"
    authors:
      - family-names: "Ferreira"
        given-names: "Rafael"
        alias: "rafjaa"
    url: "https://github.com/rafjaa/LeIA"
    license: MIT
    notes: >
      Portuguese-lexicon fork of VADER used for sentiment scoring of
      Brazilian Portuguese review text. Bundled locally in python/LeIA_lib/.

  - type: software
    title: "XGBoost: A Scalable Tree Boosting System"
    authors:
      - family-names: "Chen"
        given-names: "Tianqi"
      - family-names: "Guestrin"
        given-names: "Carlos"
    doi: "10.1145/2939672.2939785"
    url: "https://github.com/dmlc/xgboost"
    notes: >
      Used for CLV point estimation + quantile CI (objective='reg:quantileerror')
      and churn classification (objective='binary:logistic', F1-tuned threshold).

  - type: software
    title: "lifelines: Survival Analysis in Python"
    authors:
      - family-names: "Davidson-Pilon"
        given-names: "Cameron"
    url: "https://github.com/CamDavidsonPilon/lifelines"
    license: MIT
    notes: >
      WeibullAFTFitter used for next-purchase timing. predict_median with
      conditional_after parameter provides T|T>s — expected remaining time
      correctly conditioned on the customer's elapsed waiting period.

  - type: software
    title: "scikit-learn: Machine Learning in Python"
    authors:
      - name: "scikit-learn developers"
    url: "https://github.com/scikit-learn/scikit-learn"
    license: "BSD-3-Clause"
    notes: >
      K-means clustering and silhouette scoring for RFM segmentation.
      silhouette_score sample_size parameter critical for performance
      at 96k-row scale (reduced from 854s to ~20s wall time).
